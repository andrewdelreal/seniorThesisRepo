{
  "compilerOptions": {
    "target": "es6",
    "module": "nodenext",
    "jsx": "react-jsx", // or "react" for older versions
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./build",
    "rootDir": "./src"
  },
  "include": ["./src/**/*"]
}
